# ╔══════════════════════════════════════════════════════════════════╗
# ║  agent-seal v1.0 — Environment Configuration Template          ║
# ║  Copy this file to .env and fill in ALL secrets before deploy.  ║
# ║  DO NOT commit .env to version control.                         ║
# ╚══════════════════════════════════════════════════════════════════╝
#
# Quick start:
#   cp .env.example .env
#   $EDITOR .env      # fill in secrets
#   docker compose up -d
#
# All AGENT_SEAL_* / POSTGRES_* / NGINX_* variables used by
# docker-compose.yml and agent_seal/config.py are listed below.
# ══════════════════════════════════════════════════════════════════════

# ── Version ───────────────────────────────────────────────────────────
# Docker image tag.  Bump before tagging a release.
AGENT_SEAL_VERSION=1.0

# ── Core Secrets (REQUIRED — set before production deploy) ────────────
# Database connection string.  Must include host, port, user, password, dbname.
AGENT_SEAL_DB_URL=postgresql://audit:***@db:5432/agent_seal

# Flask / FastAPI secret key for session signing & CSRF tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AGENT_SEAL_SECRET_KEY=CHANGE_ME

# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=audit
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=agent_seal

# ── Redis ─────────────────────────────────────────────────────────────
AGENT_SEAL_REDIS_URI=redis://redis:6379/0

# ── Storage ───────────────────────────────────────────────────────────
# Backend override: 'jsonl' | 'sqlite' | 'postgresql' | 'auto'
# 'auto' (default) detects from the URI / audit-dir scheme.
AGENT_SEAL_STORAGE_BACKEND=postgresql

# File-system directory for JSONL / SQLite backends.
AGENT_SEAL_AUDIT_DIR=./audit_logs

# Legacy alias for AGENT_SEAL_AUDIT_DIR (deprecated, prefer AUDIT_DIR).
AGENT_SEAL_URI=./audit_logs

# ── API ───────────────────────────────────────────────────────────────
# Bind address.  0.0.0.0 in Docker; use 127.0.0.1 for local development.
AGENT_SEAL_API_HOST=0.0.0.0
AGENT_SEAL_API_PORT=8081

# Comma-separated list of pre-shared API keys for bearer-auth.
# Leave empty to disable auth (dev only; NOT for production).
AGENT_SEAL_API_KEYS=<your-api-key-1>,<your-api-key-2>

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.  Empty = block all origins.
# In production set to your frontend domain(s), e.g. https://audit.example.com
AGENT_SEAL_CORS_ORIGINS=http://localhost

# ── LLM Tracing ───────────────────────────────────────────────────────
# Automatically trace every LLM API call (0 = off, 1 = on).
# Enabling may increase storage usage significantly.
AGENT_SEAL_AUTO_TRACE=0

# Redact PII in trace payloads (0 = off, 1 = on).
AGENT_SEAL_TRACE_PII_REDACT=0

# Maximum characters per traced message (truncated if longer).
AGENT_SEAL_TRACE_MAX_LEN=4000

# Cost-estimation model: 'openai' | 'anthropic'.
AGENT_SEAL_TRACE_COST_MODEL=openai

# ── Logging ───────────────────────────────────────────────────────────
# Log level: 'debug' | 'info' | 'warning' | 'error'.
AGENT_SEAL_LOG_LEVEL=info

# Log output format: 'json' (structured, recommended for production) | 'text'.
AGENT_SEAL_LOG_FORMAT=json

# ── Notifications (optional) ──────────────────────────────────────────
# Slack incoming webhook URL.  Leave empty to disable Slack alerts.
AGENT_SEAL_SLACK_WEBHOOK=

# SMTP relay host for email alerts.  Leave empty to disable email.
# Example: smtp.gmail.com
AGENT_SEAL_SMTP_HOST=

# Enable notifications on audit-trail verification failures (0 = off, 1 = on).
AGENT_SEAL_NOTIFY_ON_FAILURE=0

# ── Signing & Encryption (optional) ───────────────────────────────────
# Ed25519 private key (PEM / Base64) for audit-trail signing.
AGENT_SEAL_SIGNING_KEY=

# Password / passphrase protecting the signing key (if encrypted).
AGENT_SEAL_SIGNING_KEY_PASSWORD=

# AES-256 encryption key (Base64) for encrypted audit storage.
AGENT_SEAL_ENCRYPTION_KEY=

# ── Evidence Store (optional) ─────────────────────────────────────────
# URI for the evidence storage backend.  Leave empty to disable.
# Example: file:///var/evidence or s3://bucket-name/prefix
AGENT_SEAL_EVIDENCE_STORE=

# ── Nginx ─────────────────────────────────────────────────────────────
# HTTP / HTTPS listen ports (mapped to host).
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
