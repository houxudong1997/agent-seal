{
  "dashboard": {
    "id": null,
    "uid": "agent-audit-overview",
    "title": "Agent Audit — Overview",
    "tags": ["agent-audit", "production"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Event Throughput",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{
          "expr": "rate(audit_events_total[5m])",
          "legendFormat": "events/s",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [{
          "expr": "rate(audit_events_total{event_type=\"error\"}[5m]) / rate(audit_events_total[5m]) * 100",
          "legendFormat": "error %",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          },
          "overrides": []
        }
      },
      {
        "id": 3,
        "title": "Active Sessions",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [{
          "expr": "audit_sessions_active",
          "legendFormat": "active sessions",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Storage Usage",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [{
          "expr": "audit_storage_bytes",
          "legendFormat": "storage",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1073741824},
                {"color": "red", "value": 5368709120}
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 5,
        "title": "Total Events",
        "type": "stat",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [{
          "expr": "audit_events_total",
          "legendFormat": "__auto",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0
          },
          "overrides": []
        }
      },
      {
        "id": 6,
        "title": "LLM Latency (P50 / P95 / P99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "SELECT percentile_cont(0.50) WITHIN GROUP (ORDER BY latency_ms) AS p50, percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms) AS p95, percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms) AS p99 FROM llm_calls WHERE $__timeFilter(created_at)",
            "format": "table",
            "rawSql": true,
            "refId": "A",
            "datasource": {"type": "postgresql", "uid": "postgresql"}
          }
        ],
        "datasource": {"type": "postgresql", "uid": "postgresql"},
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0
          },
          "overrides": []
        }
      },
      {
        "id": 7,
        "title": "Token Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [{
          "expr": "SELECT SUM(prompt_tokens) AS prompt_tokens, SUM(completion_tokens) AS completion_tokens, SUM(prompt_tokens) + SUM(completion_tokens) AS total_tokens FROM llm_calls WHERE $__timeFilter(created_at)",
          "format": "table",
          "rawSql": true,
          "refId": "A",
          "datasource": {"type": "postgresql", "uid": "postgresql"}
        }],
        "datasource": {"type": "postgresql", "uid": "postgresql"},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "min": 0
          },
          "overrides": []
        }
      },
      {
        "id": 8,
        "title": "Top Models",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [{
          "expr": "SELECT model, provider, COUNT(*) AS call_count, AVG(latency_ms)::int AS avg_latency_ms, SUM(prompt_tokens + completion_tokens) AS total_tokens FROM llm_calls GROUP BY model, provider ORDER BY call_count DESC LIMIT 10",
          "format": "table",
          "rawSql": true,
          "refId": "A",
          "datasource": {"type": "postgresql", "uid": "postgresql"}
        }],
        "datasource": {"type": "postgresql", "uid": "postgresql"}
      },
      {
        "id": 9,
        "title": "Policy Activity",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "rate(audit_policy_denials_total[5m])",
            "legendFormat": "denials/s",
            "refId": "A",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          },
          {
            "expr": "rate(audit_policy_approvals_total[5m])",
            "legendFormat": "approvals/s",
            "refId": "B",
            "datasource": {"type": "prometheus", "uid": "prometheus"}
          }
        ],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          },
          "overrides": []
        }
      },
      {
        "id": 10,
        "title": "Integrity Verifications",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
        "targets": [{
          "expr": "rate(audit_verify_checks_total[5m])",
          "legendFormat": "checks/s",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "min": 0
          },
          "overrides": []
        }
      },
      {
        "id": 11,
        "title": "Uptime",
        "type": "stat",
        "gridPos": {"h": 8, "w": 4, "x": 12, "y": 32},
        "targets": [{
          "expr": "audit_uptime_seconds",
          "legendFormat": "__auto",
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"}
        }],
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 12,
        "title": "Events by Type",
        "type": "table",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 32},
        "targets": [{
          "expr": "SELECT event_type, COUNT(*) AS count, MAX(created_at) AS last_occurrence FROM events GROUP BY event_type ORDER BY count DESC",
          "format": "table",
          "rawSql": true,
          "refId": "A",
          "datasource": {"type": "postgresql", "uid": "postgresql"}
        }],
        "datasource": {"type": "postgresql", "uid": "postgresql"}
      }
    ],
    "templating": {
      "list": [
        {
          "name": "datasource",
          "type": "datasource",
          "query": "prometheus",
          "current": {"text": "Prometheus", "value": "prometheus"},
          "hide": 0
        }
      ]
    },
